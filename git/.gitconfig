[color]
	ui = true
[user]
	name = Federico Sapuppo
	email = fedesapuppo@hotmail.com
[init]
	defaultBranch = main
[core]
	editor = nvim
[gui]
	uicolor = grey85
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
[commit]
	verbose = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = -version:refname
[rerere]
	enabled = true
	autoupdate = true
[fetch]
	prune = true
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status --short
	ca = commit -a
	aa = add --all
	ap = add --patch
	df = diff
	dig = blame
	lg = log -p
	lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
	ls = ls-files
	wdiff = diff -w --word-diff=color
	wip = !git commit -am wip
	wshow = show -w --word-diff=color
	pf = push --force-with-lease
	changelog = log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --date=relative --abbrev-commit --graph
	branches = for-each-ref --sort=-committerdate --format=\"%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)\" refs/remotes
