# =============================================================================
# secrets.env.example — template for machine-local secrets
#
# Copy to ~/.secrets.env and fill in real (rotated) values.
# ~/.secrets.env is gitignored and MUST NEVER be committed.
# Sourced automatically by shell/.zshrc and shell/.bashrc.
#
#   cp shell/secrets.env.example ~/.secrets.env && chmod 600 ~/.secrets.env
# =============================================================================

# Atlassian (Jira/Confluence) — site, account email, API token
export ATLASSIAN_SITE_NAME=""
export ATLASSIAN_USER_EMAIL=""
export ATLASSIAN_API_TOKEN=""

# Anthropic API key
export ANTHROPIC_API_KEY=""

# Financial Modeling Prep API key
export FMP_KEY=""

# Bonsai.ai API key — https://www.trybons.ai/
export BONSAI_API_KEY=""

# npm registry auth token (consumed by npm/.npmrc via ${NPM_TOKEN})
export NPM_TOKEN=""

# Bundler: GraphQL Pro credentials ("<user>:<token>")
export BUNDLE_GEMS__GRAPHQL__PRO=""

# Bundler: GitHub Packages credentials ("<user>:ghp_...")
export BUNDLE_RUBYGEMS__PKG__GITHUB__COM=""
